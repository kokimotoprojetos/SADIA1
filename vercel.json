{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "^/?$", "dest": "/api/index.php" },
    { "src": "/(.*)\\.(css|js|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot|map|json)$", "dest": "/$1.$2" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}